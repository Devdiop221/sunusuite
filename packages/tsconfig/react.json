{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "SunuSuite – React / Vite",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "useDefineForClassFields": true
  }
}
