{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "node",
        "target": "ES2021",
        "lib": [
            "ES2021"
        ],
        "outDir": "./dist",
        "rootDir": "./src",
        "paths": {
            "@sunusuite/types": [
                "../../packages/types/src/index.ts"
            ]
        },
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "incremental": true,
        "strictNullChecks": true,
        "noUnusedLocals": false
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "test"
    ]
}